<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>
    body { font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 2rem; color: #173f3f; }
    main { max-width: 960px; margin: 0 auto; }
    h1, h2 { color: #155353; }
    table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
    th, td { border: 1px solid #c8dddd; padding: 0.45rem 0.55rem; text-align: left; }
    th { background: #eef7f7; }
    .metrics { display: grid; grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr)); gap: 0.75rem; }
    .metric { border: 1px solid #c8dddd; border-radius: 0.35rem; padding: 0.75rem; background: #f8fcfc; }
    .metric strong { display: block; font-size: 1.4rem; color: #155353; }
    .note { border-left: 4px solid #1e6b6b; padding: 0.75rem 1rem; background: #f4fbfb; }
    img { max-width: 100%; border: 1px solid #d7e6e6; border-radius: 0.35rem; }
  </style>
</head>
<body>
<main>
  <h1>{{ title }}</h1>
  <p class="note">{{ summary_note }}</p>

  <section class="metrics">
    <div class="metric"><span>Samples</span><strong>{{ metrics.sample_count }}</strong></div>
    <div class="metric"><span>Genes tested</span><strong>{{ metrics.gene_count }}</strong></div>
    <div class="metric"><span>Significant genes</span><strong>{{ metrics.significant_count }}</strong></div>
    <div class="metric"><span>Contrast</span><strong>{{ metrics.contrast }}</strong></div>
  </section>

  <h2>Top genes</h2>
  {{ top_genes_table }}

  <h2>Diagnostic plots</h2>
  <p>The portfolio page embeds these same files for a compact web preview.</p>
  <p><img src="volcano.png" alt="Volcano plot"></p>
  <p><img src="pca.png" alt="PCA plot"></p>
</main>
</body>
</html>
