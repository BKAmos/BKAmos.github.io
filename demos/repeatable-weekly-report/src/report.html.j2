<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Weekly operations report — {{ report_week }}</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 52rem; margin: 2rem auto; color: #222; }
    h1 { color: #157878; }
    table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
    th, td { border: 1px solid #ccc; padding: 0.4rem 0.6rem; text-align: left; }
    th { background: #f4fafa; }
    .muted { color: #555; font-size: 0.95rem; }
    .callout { background: #f4fafa; border-left: 4px solid #157878; padding: 0.75rem 1rem; margin: 1rem 0; }
  </style>
</head>
<body>
  <h1>Weekly operations report</h1>
  <p class="muted">Report week: <strong>{{ report_week }}</strong> · Synthetic demo data</p>

  <div class="callout">
    <strong>Highlights</strong>
    <ul>
      {% for line in highlights %}
      <li>{{ line }}</li>
      {% endfor %}
    </ul>
  </div>

  <h2>Weekly KPIs</h2>
  {{ kpi_table }}

  <h2>Incidents</h2>
  {% if incidents.empty %}
  <p>No incidents recorded this period.</p>
  {% else %}
  {{ incidents_table }}
  {% endif %}

  <p class="muted">Generated by Python (pandas + Jinja2). Source: <code>demos/repeatable-weekly-report/</code></p>
</body>
</html>
